<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" id="Definitions_AgentOpsCaseControlRoom" targetNamespace="https://example.local/agentops-case-control-room"><bpmn:process id="Process_AgentOpsCaseControlRoom" name="AgentOps Case Control Room" isExecutable="false"><bpmn:startEvent id="start_case" name="Production release exception opened"><bpmn:documentation>Evidence events: evt-0001</bpmn:documentation></bpmn:startEvent><bpmn:task id="agent_investigation" name="Agent creates read-only investigation plan and runs verification"><bpmn:documentation>Evidence events: evt-0002, evt-0005</bpmn:documentation></bpmn:task><bpmn:task id="collect_release_context" name="Robot gathers change ticket, PR, deployment, and owner context"><bpmn:documentation>Evidence events: evt-0003, evt-0004</bpmn:documentation></bpmn:task><bpmn:exclusiveGateway id="risk_gateway" name="Is production action risky or under-evidenced?"><bpmn:documentation>Evidence events: evt-0006, evt-0007</bpmn:documentation></bpmn:exclusiveGateway><bpmn:task id="human_approval" name="Operations lead reviews evidence and asks for more context"><bpmn:documentation>Evidence events: evt-0008</bpmn:documentation></bpmn:task><bpmn:task id="owner_signoff" name="Service owner rejects release until regression is fixed"><bpmn:documentation>Evidence events: evt-0009, evt-0010</bpmn:documentation></bpmn:task><bpmn:task id="write_handoff" name="Generate event-linked handoff report"><bpmn:documentation>Evidence events: evt-0011</bpmn:documentation></bpmn:task><bpmn:endEvent id="end_case" name="Release rejected until evidence is fixed" /><bpmn:sequenceFlow id="Flow_01" sourceRef="start_case" targetRef="agent_investigation" /><bpmn:sequenceFlow id="Flow_02" sourceRef="agent_investigation" targetRef="collect_release_context" /><bpmn:sequenceFlow id="Flow_03" sourceRef="collect_release_context" targetRef="risk_gateway" /><bpmn:sequenceFlow id="Flow_04" sourceRef="risk_gateway" targetRef="human_approval" /><bpmn:sequenceFlow id="Flow_05" sourceRef="human_approval" targetRef="owner_signoff" /><bpmn:sequenceFlow id="Flow_06" sourceRef="owner_signoff" targetRef="write_handoff" /><bpmn:sequenceFlow id="Flow_07" sourceRef="write_handoff" targetRef="end_case" /></bpmn:process></bpmn:definitions>